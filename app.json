{
  "expo": {
    "name": "Boğazlıyan",
    "slug": "bogazliyanmobil2026",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/images/logo_1024.png",
    "scheme": "bogazliyanmobil2026",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "googleServicesFile": "./src/firebase/GoogleService-Info.plist",
      "supportsTablet": true,
      "bundleIdentifier": "com.bogazliyanmobil.bogazliyanmobil2026",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo_1024.png",
        "backgroundImage": "./assets/images/logo_background.png",
        "monochromeImage": "./assets/images/logo_1024.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bogazliyanmobil.bogazliyanmobil2026",
      "googleServicesFile": "./src/firebase/google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_1024.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],

      "@react-native-firebase/app"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}